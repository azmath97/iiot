import RPi.GPIO as GPIO
import time

GPIO.setmode(GPIO.BCM)
rain_pin = 27
GPIO.setup(rain_pin, GPIO.IN)

try:
    while True:
        if GPIO.input(rain_pin) == 0:
            print("Rain Detected")
        else:
            print("No Rain")
        time.sleep(0.5)

except KeyboardInterrupt:
    print("Program Stopped")

finally:
    GPIO.cleanup()
